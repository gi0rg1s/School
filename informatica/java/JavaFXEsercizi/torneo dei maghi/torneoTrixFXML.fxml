<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: linear-gradient(to bottom, #f5f9ff, #e8f0ff);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TrixController">
   <top>
      <VBox alignment="CENTER" spacing="4.0" BorderPane.alignment="CENTER" style="-fx-text-alignment: center; -fx-background-color: #e8f0ff; -fx-border-color: #b8ccff; -fx-border-width: 0 0 1 0;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #3c52d9;" text="Trix" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Scegli la tua avversaria" />
         </children>
         <padding>
            <Insets bottom="10.0" left="12.0" right="12.0" top="12.0" />
         </padding>
      </VBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="selectedButton" disable="true" mnemonicParsing="false" onAction="#onSelectedButtonClicked" style="-fx-background-color: #5a7cff; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 8 16;" text="Combatti" />
            <Button fx:id="close_btn" mnemonicParsing="false" onAction="#close_stage" style="-fx-background-color: #c8d6ff; -fx-text-fill: #2d3f9f; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 8 16;" text="Chiudi" />
         </children>
         <BorderPane.margin>
