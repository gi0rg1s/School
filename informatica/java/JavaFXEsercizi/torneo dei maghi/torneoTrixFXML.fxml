<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>


<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="TrixController">
   <top>
      <VBox alignment="CENTER" spacing="4.0" BorderPane.alignment="CENTER" style="-fx-text-alignment: center;">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #270075;" text="Trix" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #555555;" text="Scegli la tua avversaria" />
         </children>
         <padding>
            <Insets bottom="10.0" left="12.0" right="12.0" top="12.0" />
         </padding>
      </VBox>
   </top>
   <bottom>
      <HBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="selectedButton" disable="true" mnemonicParsing="false" text="Combatti" />
            <Button fx:id="close_btn" mnemonicParsing="false" onAction="#close_stage" text="Chiudi" />
         </children>
         <BorderPane.margin>
            <Insets bottom="8.0" />
         </BorderPane.margin>
      </HBox>
   </bottom>
   <center>
      <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <content>
            <TilePane fx:id="trixContainer" hgap="12.0" prefColumns="3" prefHeight="200.0" prefWidth="200.0" vgap="12.0" />
         </content>
      </ScrollPane>
   </center>
</BorderPane>
