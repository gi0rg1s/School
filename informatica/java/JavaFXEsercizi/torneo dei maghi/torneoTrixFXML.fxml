         </BorderPane.margin>
      </HBox>
   </bottom>
   <center>
      <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" style="-fx-background: transparent; -fx-background-color: transparent; -fx-control-inner-background: transparent;" BorderPane.alignment="CENTER">
         <content>
            <TilePane fx:id="trixContainer" hgap="12.0" prefColumns="3" prefHeight="200.0" prefWidth="200.0" style="-fx-padding: 12;" vgap="12.0" />
         </content>
      </ScrollPane>
   </center>
</BorderPane>
